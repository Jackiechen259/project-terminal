{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Project Terminal",
  "version": "0.4.3",
  "identifier": "com.projectterminal.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Project Terminal",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": false,
        "fullscreen": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": false,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Project Terminal",
    "longDescription": "A Windows desktop terminal organized by projects with isolated per-project terminal tab groups."
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEyNDg0QTREMDlBMkMwRDkKUldUWndLSUpUVXBJb2xtVTBsMWwweWxlTDd5alpZNUxkeDkvV3UxaEVKK0hSNXZ6cnE4QnozdEEK",
      "endpoints": [
        "https://github.com/Jackiechen259/project-terminal/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
